{
  "name": "ink-trace",
  "version": "1.0.0",
  "description": "基于 Electron + Vue 3 + SQLite 的写作管理器",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder",
    "dev:full": "concurrently \"npm run dev\" \"npm run electron:dev\"",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepare": "husky install || true"
  },
  "keywords": ["writing", "electron", "vue", "sqlite"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^29.0.0",
    "vue": "^3.4.0",
    "sqlite3": "^5.1.6",
    "better-sqlite3": "^9.0.0",
    "pinia": "^2.1.7",
    "vue-router": "^4.2.0",
    "element-plus": "^2.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0",
    "vitest": "^1.2.0",
    "@vue/test-utils": "^2.4.0",
    "playwright": "^1.40.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.inktrace.app",
    "productName": "InkTrace",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}